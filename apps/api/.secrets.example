# Local developer secrets only — copy to `.secrets.env` (gitignored).
# Staging/production must inject via process environment when needed.
# Values below are clearly invalid examples — never use in real deployments.

# Required when BERGAMA_BOOTSTRAP_AUTH_ENABLED=true (local/test JWT bootstrap).
BERGAMA_SECRETS__BOOTSTRAP_JWT_SIGNING_KEY=replace-me-with-local-dev-only-jwt-key-0001

# Optional — reserved; not required by current runtime.
# BERGAMA_SECRETS__APP_SECRET_KEY=replace-me-with-local-dev-only-app-secret-0001

# Polygon historical (#302) — only when BERGAMA_POLYGON__ENABLED=true.
# Prefer this secret file over committing keys. Never commit a real value.
# BERGAMA_POLYGON__API_KEY=replace-me-with-local-dev-only-polygon-key
