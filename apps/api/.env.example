# Local development only — gitignored as `.env`.
# Staging/production must inject variables; do not rely on this file.

BERGAMA_ENVIRONMENT=local
BERGAMA_APP_NAME=Bergama Trading API
BERGAMA_APP_VERSION=0.2.0
BERGAMA_DEBUG=true
BERGAMA_LOG_LEVEL=INFO
BERGAMA_API_PREFIX=/api/v1
BERGAMA_DOCS_ENABLED=true
BERGAMA_OPENAPI_ENABLED=true
BERGAMA_REQUEST_TIMEOUT_SECONDS=30
BERGAMA_SHUTDOWN_TIMEOUT_SECONDS=15
BERGAMA_SERVICE_NAME=bergama-api
BERGAMA_INSTANCE_ID=local-1
BERGAMA_HOST=0.0.0.0
BERGAMA_PORT=8000

# JWT bootstrap (#205) — local/test only. Staging/production must keep this false.
BERGAMA_BOOTSTRAP_AUTH_ENABLED=true
BERGAMA_JWT_ALGORITHM=HS256
BERGAMA_JWT_ISSUER=bergama-api
BERGAMA_JWT_AUDIENCE=bergama-api
BERGAMA_JWT_ACCESS_TOKEN_TTL_SECONDS=900

# Health runtime (#207)
BERGAMA_HEALTH_CHECK_TIMEOUT_SECONDS=2
BERGAMA_HEALTH_TOTAL_TIMEOUT_SECONDS=5
# Leave hosts unset to skip TCP checks (status=skipped).
# BERGAMA_POSTGRES_HOST=
# BERGAMA_REDIS_HOST=
BERGAMA_POSTGRES_REQUIRED=false
BERGAMA_REDIS_REQUIRED=false

# Kafka runtime (#208A) — disabled by default for local/test stability.
BERGAMA_KAFKA__ENABLED=false
BERGAMA_KAFKA__BOOTSTRAP_SERVERS=
BERGAMA_KAFKA__CLIENT_ID=bergama-api
BERGAMA_KAFKA__CONSUMER_GROUP_ID=bergama-api-runtime
BERGAMA_KAFKA__ENABLE_AUTO_COMMIT=false
BERGAMA_KAFKA__PRODUCER_ENABLED=true
BERGAMA_KAFKA__CONSUMER_ENABLED=false
BERGAMA_KAFKA__HEALTH_REQUIRED=false
# BERGAMA_KAFKA__TOPIC_PREFIX=
# Topics are not auto-created by the API. Provision Sprint 1 topics explicitly:
# market-data, events, audit, execution, risk

# Market data orchestrator (#305/#306) — disabled by default.
BERGAMA_ORCHESTRATOR__ENABLED=false
BERGAMA_ORCHESTRATOR__DRY_RUN=false
# none = inject PublishPort (or dry_run); kafka = KafkaPublishAdapter (requires Kafka producer)
BERGAMA_ORCHESTRATOR__PUBLISH_BACKEND=none
# BERGAMA_ORCHESTRATOR__PIPELINE_NAME=market-data-orchestrator
# Optional live smoke for #306: BERGAMA_KAFKA_PUBLISH_SMOKE=1 (topic market-data must exist)

# Iceberg market-data writer (#307) — disabled by default; append-only; at-least-once.
# Requires Kafka when enabled. Tables must pre-exist unless auto_create_tables (local/test only).
BERGAMA_ICEBERG_WRITER__ENABLED=false
BERGAMA_ICEBERG_WRITER__REQUIRED=false
BERGAMA_ICEBERG_WRITER__CATALOG_TYPE=rest
# BERGAMA_ICEBERG_WRITER__CATALOG_URI=http://127.0.0.1:8181
# BERGAMA_ICEBERG_WRITER__WAREHOUSE=s3://bergama-warehouse/
BERGAMA_ICEBERG_WRITER__NAMESPACE=bergama
BERGAMA_ICEBERG_WRITER__TABLE_PREFIX=
# BERGAMA_ICEBERG_WRITER__S3_ENDPOINT=http://127.0.0.1:9000
BERGAMA_ICEBERG_WRITER__S3_REGION=us-east-1
BERGAMA_ICEBERG_WRITER__PATH_STYLE_ACCESS=true
BERGAMA_ICEBERG_WRITER__BATCH_MAX_RECORDS=100
BERGAMA_ICEBERG_WRITER__BATCH_MAX_BYTES=1048576
BERGAMA_ICEBERG_WRITER__FLUSH_INTERVAL_SECONDS=2
BERGAMA_ICEBERG_WRITER__CONSUMER_GROUP_ID=bergama-iceberg-writer
BERGAMA_ICEBERG_WRITER__AUTO_CREATE_TABLES=false
BERGAMA_ICEBERG_WRITER__COMMITTED_KEY_TTL_SECONDS=3600
BERGAMA_ICEBERG_WRITER__COMMITTED_KEY_MAX_ENTRIES=100000
# Put object-store credentials in `.secrets.env` only:
# BERGAMA_ICEBERG_WRITER__ACCESS_KEY=
# BERGAMA_ICEBERG_WRITER__SECRET_KEY=
# Optional live smoke: BERGAMA_ICEBERG_WRITER_SMOKE=1 (Kafka + catalog + MinIO; pre-created topic/tables)

# Replay Engine (#308) — disabled by default; default mode dry_run; no production sink config.
BERGAMA_REPLAY__ENABLED=false
BERGAMA_REPLAY__DEFAULT_MODE=dry_run
BERGAMA_REPLAY__MAX_TIME_RANGE_DAYS=31
BERGAMA_REPLAY__MAX_RECORDS=10000
BERGAMA_REPLAY__DEFAULT_BATCH_SIZE=100
BERGAMA_REPLAY__MAX_BATCH_SIZE=1000
BERGAMA_REPLAY__DEFAULT_MAX_IN_FLIGHT=1
BERGAMA_REPLAY__CHECKPOINT_ENABLED=true
# Absolute path required when enabled + checkpoints on:
# BERGAMA_REPLAY__CHECKPOINT_DIRECTORY=/var/lib/bergama/replay-checkpoints
# BERGAMA_REPLAY__DEFAULT_EVENTS_PER_SECOND=
# Optional local smoke: BERGAMA_REPLAY_ENGINE_SMOKE=1 (local Iceberg tables, dry-run)

# Polygon historical + realtime connectors (#302/#303) — disabled by default; no real key in git.
BERGAMA_POLYGON__ENABLED=false
BERGAMA_POLYGON__BASE_URL=https://api.polygon.io
BERGAMA_POLYGON__WEBSOCKET_ENABLED=false
BERGAMA_POLYGON__WEBSOCKET_URL=wss://socket.polygon.io/stocks
# Put the API key in `.secrets.env` only, never commit it:
# BERGAMA_POLYGON__API_KEY=
# Optional live smoke: BERGAMA_POLYGON_SMOKE=1 (REST) or BERGAMA_POLYGON_WS_SMOKE=1 (WebSocket)

# Finnhub fundamentals/reference connector (#304A) — disabled by default; no real key in git.
BERGAMA_FINNHUB__ENABLED=false
BERGAMA_FINNHUB__BASE_URL=https://finnhub.io/api/v1
# Put the API key in `.secrets.env` only, never commit it:
# BERGAMA_FINNHUB__API_KEY=
# Optional live smoke: BERGAMA_FINNHUB_SMOKE=1

# FRED macro connector (#304B) — disabled by default; no real key in git.
BERGAMA_FRED__ENABLED=false
BERGAMA_FRED__BASE_URL=https://api.stlouisfed.org
# Put the API key in `.secrets.env` only, never commit it:
# BERGAMA_FRED__API_KEY=
# Optional live smoke: BERGAMA_FRED_SMOKE=1

# SEC EDGAR filings connector (#304C) — disabled by default; no API key.
BERGAMA_SEC__ENABLED=false
BERGAMA_SEC__BASE_URL=https://data.sec.gov
BERGAMA_SEC__ARCHIVES_BASE_URL=https://www.sec.gov
BERGAMA_SEC__APPLICATION_NAME=BergamaTrading
# Required when enabled (use a real reachable contact; placeholders are rejected):
# BERGAMA_SEC__CONTACT_EMAIL=you@your-domain.example
# Or set an explicit User-Agent including contact email:
# BERGAMA_SEC__USER_AGENT=BergamaTrading you@your-domain.example
# Optional live smoke: BERGAMA_SEC_SMOKE=1

# Benzinga news connector (#304D) — disabled by default; no real key in git.
BERGAMA_BENZINGA__ENABLED=false
BERGAMA_BENZINGA__BASE_URL=https://api.benzinga.com
BERGAMA_BENZINGA__DEFAULT_DISPLAY_OUTPUT=abstract
# Put the API key in `.secrets.env` only, never commit it:
# BERGAMA_BENZINGA__API_KEY=
# Optional live smoke: BERGAMA_BENZINGA_SMOKE=1

# Secrets live in `.secrets.env` (see `.secrets.example`), not in this file.
# Required for local bootstrap: BERGAMA_SECRETS__BOOTSTRAP_JWT_SIGNING_KEY
# Optional: BERGAMA_SECRETS__APP_SECRET_KEY (unused by current runtime)
