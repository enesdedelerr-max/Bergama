# Local development only — gitignored as `.env`.
# Staging/production must inject variables; do not rely on this file.

BERGAMA_ENVIRONMENT=local
BERGAMA_APP_NAME=Bergama Trading API
BERGAMA_APP_VERSION=0.2.0
BERGAMA_DEBUG=true
BERGAMA_LOG_LEVEL=INFO
BERGAMA_API_PREFIX=/api/v1
BERGAMA_DOCS_ENABLED=true
BERGAMA_OPENAPI_ENABLED=true
BERGAMA_REQUEST_TIMEOUT_SECONDS=30
BERGAMA_SHUTDOWN_TIMEOUT_SECONDS=15
BERGAMA_SERVICE_NAME=bergama-api
BERGAMA_INSTANCE_ID=local-1
BERGAMA_HOST=0.0.0.0
BERGAMA_PORT=8000

# JWT bootstrap (#205) — local/test only. Staging/production must keep this false.
BERGAMA_BOOTSTRAP_AUTH_ENABLED=true
BERGAMA_JWT_ALGORITHM=HS256
BERGAMA_JWT_ISSUER=bergama-api
BERGAMA_JWT_AUDIENCE=bergama-api
BERGAMA_JWT_ACCESS_TOKEN_TTL_SECONDS=900

# Health runtime (#207)
BERGAMA_HEALTH_CHECK_TIMEOUT_SECONDS=2
BERGAMA_HEALTH_TOTAL_TIMEOUT_SECONDS=5
# Leave hosts unset to skip TCP checks (status=skipped).
# BERGAMA_POSTGRES_HOST=
# BERGAMA_REDIS_HOST=
BERGAMA_POSTGRES_REQUIRED=false
BERGAMA_REDIS_REQUIRED=false

# Kafka runtime (#208A) — disabled by default for local/test stability.
BERGAMA_KAFKA__ENABLED=false
BERGAMA_KAFKA__BOOTSTRAP_SERVERS=
BERGAMA_KAFKA__CLIENT_ID=bergama-api
BERGAMA_KAFKA__CONSUMER_GROUP_ID=bergama-api-runtime
BERGAMA_KAFKA__ENABLE_AUTO_COMMIT=false
BERGAMA_KAFKA__PRODUCER_ENABLED=true
BERGAMA_KAFKA__CONSUMER_ENABLED=false
BERGAMA_KAFKA__HEALTH_REQUIRED=false
# BERGAMA_KAFKA__TOPIC_PREFIX=
# Topics are not auto-created by the API. Provision Sprint 1 topics explicitly:
# market-data, events, audit, execution, risk

# Polygon historical + realtime connectors (#302/#303) — disabled by default; no real key in git.
BERGAMA_POLYGON__ENABLED=false
BERGAMA_POLYGON__BASE_URL=https://api.polygon.io
BERGAMA_POLYGON__WEBSOCKET_ENABLED=false
BERGAMA_POLYGON__WEBSOCKET_URL=wss://socket.polygon.io/stocks
# Put the API key in `.secrets.env` only, never commit it:
# BERGAMA_POLYGON__API_KEY=
# Optional live smoke: BERGAMA_POLYGON_SMOKE=1 (REST) or BERGAMA_POLYGON_WS_SMOKE=1 (WebSocket)

# Finnhub fundamentals/reference connector (#304A) — disabled by default; no real key in git.
BERGAMA_FINNHUB__ENABLED=false
BERGAMA_FINNHUB__BASE_URL=https://finnhub.io/api/v1
# Put the API key in `.secrets.env` only, never commit it:
# BERGAMA_FINNHUB__API_KEY=
# Optional live smoke: BERGAMA_FINNHUB_SMOKE=1

# Secrets live in `.secrets.env` (see `.secrets.example`), not in this file.
# Required for local bootstrap: BERGAMA_SECRETS__BOOTSTRAP_JWT_SIGNING_KEY
# Optional: BERGAMA_SECRETS__APP_SECRET_KEY (unused by current runtime)
